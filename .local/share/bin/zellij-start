#!/bin/sh



# handle parameters
if [ $# -gt 0 ]; then
    if [ "$1" = "new" ]; then
        exec zellij
    else
        exec zellij "$@"
    fi
    exit $?
fi


list_sessions() {
    zellij list-sessions -n --short 2> /dev/null
}


create_session() {
    name=$1

    nohup zellij -n $name --session $name >/dev/null 2>&1 < /dev/null &
}

# if ! echo $sessions | grep -qx config; then
#     nohup zellij -n config --session config >/dev/null 2>&1 < /dev/null &
# fi
#
# if ! echo $sessions | grep -qx default; then
#     nohup zellij -n default --session default >/dev/null 2>&1 < /dev/null &
# fi

wait_for_sessions() {
    sessions="$1"

    for session in $sessions; do
        while true; do
            if  list_sessions | grep -qx "$session" ; then
                break
            fi

            sleep 0.1
        done
    done
}


sessions="config default"

for session in $sessions; do
    if ! echo $sessions | grep -qx $session; then
        create_session $session
    fi
done

wait_for_sessions "$sessions"



zellij attach "default"
